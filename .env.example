# Copy this file to .env and fill in your own keys.
#   cp .env.example .env
#
# .env is gitignored and must never be committed.
# Only the live benchmark needs these. Reproducing the paper's tables does not:
#   python run_benchmark.py --offline     <- no key required
#
# Get a free Gemini key at https://aistudio.google.com/apikey

GEMINI_API_KEY=your-gemini-api-key-here

# Optional. Used automatically when the primary key hits its quota.
GEMINI_API_KEY_BACKUP=your-backup-gemini-api-key-here
